{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Mini OJ (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "fastapi",
      "args": [
        "dev",
        "app/main.py"
      ],
      "env": {
        "PYTHONUTF8": "1"
      },
      "jinja": true,
      "console": "integratedTerminal"
    }
  ]
}
